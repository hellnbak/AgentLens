{
  "uid": "agentlens-endpoint-health",
  "title": "AgentLens Endpoint Health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Findings",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(agentlens_findings_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Processed Events",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(agentlens_processed_events_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Estimated Cost USD",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(agentlens_estimated_cost_usd_total)",
          "refId": "A"
        }
      ]
    }
  ]
}