{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/agentlens-event.schema.json",
  "title": "AgentLens Normalized Event",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "user": {
      "type": [
        "string",
        "null"
      ]
    },
    "team": {
      "type": [
        "string",
        "null"
      ]
    },
    "repo": {
      "type": [
        "string",
        "null"
      ]
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tool_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "dlp_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "estimated_cost_usd": {
      "type": "number"
    },
    "input_tokens": {
      "type": "integer"
    },
    "output_tokens": {
      "type": "integer"
    },
    "timestamp": {
      "type": "string"
    }
  },
  "additionalProperties": true
}