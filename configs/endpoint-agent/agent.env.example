# AgentLens endpoint agent managed configuration.
# Push this through MDM/device management and protect it with root/admin ownership.

AGENTLENS_UPSTREAM_ENDPOINT=otel-gateway.example.com:4317
AGENTLENS_UPSTREAM_INSECURE=false
AGENTLENS_ENDPOINT_ID=replace-with-device-id-or-serial
AGENTLENS_API_KEY=replace-with-enrollment-or-collector-key
AGENTLENS_LOCAL_LOG_FILE=/var/log/agentlens/endpoint-agent-logs.jsonl
AGENTLENS_WATCHDOG_LOG_FILE=/var/log/agentlens/endpoint-watchdog.jsonl

# Optional governance metadata. Device management should template these values.
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,team=unknown,user.email=unknown,device.owner=unknown,endpoint.managed_by=unknown

# Optional uninstall control. Set a random per-org or per-device token and keep it in your MDM/secrets system.
AGENTLENS_UNINSTALL_TOKEN=change-me-long-random-token
